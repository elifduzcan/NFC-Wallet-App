<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Başlık -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👤 CPA — Müşteri"
            android:textColor="#E6EDF3"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="16dp"
            android:background="#161B22"
            android:layout_marginBottom="16dp"/>

        <!-- Durum -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ GÜVENSİZ MOD | Saldırı Yok"
            android:textColor="#F0883E"
            android:textSize="13sp"
            android:padding="12dp"
            android:background="#1C1600"
            android:layout_marginBottom="16dp"/>

        <!-- Kart Bilgileri -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#161B22"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💳 Kart Bilgileri"
                android:textColor="#8B949E"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etCardNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Kart Numarası"
                android:inputType="number"
                android:textColor="#E6EDF3"
                android:textColorHint="#484F58"
                android:backgroundTint="#30363D"
                android:padding="10dp"
                android:layout_marginBottom="8dp"
                android:text="4111 1111 1111 1111"/>

            <EditText
                android:id="@+id/etAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tutar (TL)"
                android:inputType="numberDecimal"
                android:textColor="#E6EDF3"
                android:textColorHint="#484F58"
                android:backgroundTint="#30363D"
                android:padding="10dp"
                android:text="100.00"/>
        </LinearLayout>

        <!-- Güvenlik Modu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#161B22"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔒 Güvenli Mod (AES+HMAC+Token)"
                android:textColor="#E6EDF3"
                android:textSize="14sp"/>

            <Switch
                android:id="@+id/swSecure"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#58A6FF"
                android:trackTint="#1F3A5F"/>
        </LinearLayout>

        <!-- Saldırı Modu Seçimi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#161B22"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚔️ Saldırı / Tamper Modu"
                android:textColor="#8B949E"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <Spinner
                android:id="@+id/spinnerTamper"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#21262D"
                android:padding="4dp"
                android:layout_marginBottom="12dp"/>

            <!-- Açıklama Kutusu -->
            <TextView
                android:id="@+id/tvTamperDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✅ Normal işlem — manipülasyon yok"
                android:textColor="#8B949E"
                android:textSize="12sp"
                android:padding="10dp"
                android:background="#0D1117"
                android:lineSpacingExtra="4dp"/>
        </LinearLayout>

        <!-- Kaydet Butonu -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="💾 Ayarları Kaydet &amp; Hazırla"
            android:textColor="#FFFFFF"
            android:backgroundTint="#238636"
            android:layout_marginBottom="16dp"/>

        <!-- Son Gönderilen Payload -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#161B22"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📤 Son Gönderilen Payload (Eavesdropping Logu)"
                android:textColor="#8B949E"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvLastPayload"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Henüz payload gönderilmedi."
                android:textColor="#58A6FF"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:padding="8dp"
                android:background="#0D1117"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
